# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/

# Raw audio data
# data/audio/ is now tracked via git-lfs (*.mp3, see .gitattributes) so it can
# move between PCs without a slow re-download. Metadata cache / synth test
# data stay untracked (small/throwaway, regenerate fast).
/data/jamendo/
/data/synth_audio/

# Logs (not source)
/logs/

# Report / submission artifacts (binary, not source)
*.pptx
*.pdf

# Streamlit / secrets
.streamlit/secrets.toml
.env
.env.*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
